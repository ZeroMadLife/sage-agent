{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "summary",
    "evidence",
    "reproduction",
    "changed_files",
    "tests",
    "risk_reasons",
    "suggested_tier",
    "confidence"
  ],
  "properties": {
    "verdict": {"enum": ["NO_OP", "FIX", "REPORT", "BLOCKED"]},
    "summary": {"type": "string", "minLength": 1, "maxLength": 500},
    "evidence": {"type": "array", "maxItems": 10, "items": {"type": "string", "maxLength": 500}},
    "reproduction": {"type": "array", "maxItems": 10, "items": {"type": "string", "maxLength": 500}},
    "changed_files": {"type": "array", "maxItems": 3, "items": {"type": "string", "maxLength": 240}},
    "tests": {"type": "array", "maxItems": 10, "items": {"type": "string", "maxLength": 500}},
    "risk_reasons": {"type": "array", "maxItems": 10, "items": {"type": "string", "maxLength": 500}},
    "suggested_tier": {"enum": ["A", "B", "C"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
