# 复制到服务器 /etc/sage/env，权限必须为 600。不要提交真实值。
COMPOSE_PROJECT_NAME=sage-canary
SAGE_IMAGE_TAG=0000000000000000000000000000000000000000
SAGE_DOCKER_REGISTRY=docker.m.daocloud.io
SAGE_GATEWAY_PORT=8080
SAGE_API_UID=0
SAGE_API_GID=0
# API 只挂载 sage-deploy 用户拥有的 0600 代理 socket；代理目标是独立 sandbox daemon。
SAGE_ROOTLESS_DOCKER_SOCKET=/run/user/1002/sage-sandbox.sock
SAGE_SANDBOX_DOCKER_SOCKET=/run/user/1003/docker.sock
SAGE_SANDBOX_UID=1003

APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
APP_ACCESS_CODES=

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sage
POSTGRES_PASSWORD=REPLACE_WITH_RANDOM_DATABASE_PASSWORD
POSTGRES_DB=sage

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_RANDOM_REDIS_PASSWORD
REDIS_DB=0

CLOUD_DEV_LOGIN_ENABLED=false
CLOUD_FRONTEND_URL=https://REPLACE_WITH_TAILSCALE_DNS_NAME
GITHUB_OAUTH_CLIENT_ID=REPLACE_WITH_GITHUB_OAUTH_CLIENT_ID
GITHUB_OAUTH_CLIENT_SECRET=REPLACE_WITH_GITHUB_OAUTH_CLIENT_SECRET
GITHUB_OAUTH_REDIRECT_URI=https://REPLACE_WITH_TAILSCALE_DNS_NAME/api/v1/cloud/auth/github/callback
GITHUB_OAUTH_SCOPE=read:user user:email
GITHUB_OAUTH_TRANSACTION_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
GITHUB_TOKEN_ENCRYPTION_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
MODEL_PROVIDER_ENCRYPTION_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS

SAGE_DEERFLOW_V2_ENABLED=true
SAGE_CODING_DEFAULT_RUNTIME_PROFILE=deerflow_v2
SAGE_CODING_SANDBOX_PROVIDER=container
SAGE_CODING_SANDBOX_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
SAGE_CODING_WORKSPACE_ROOT=/opt/sage/data/workspaces
SAGE_CODING_STORAGE_ROOT=/opt/sage/data/coding
SAGE_CODING_SETTINGS_FILE=/opt/sage/config/coding-settings.json
SAGE_MCP_LIVE_ENABLED=false

KNOWLEDGE_WORKSPACE_ROOT=/opt/sage/data/knowledge
KNOWLEDGE_DATABASE_PATH=/opt/sage/data/knowledge/.sage/knowledge.sqlite3
KNOWLEDGE_JOBS_ENABLED=false

# 至少配置一个可用模型 Provider；也可以登录后在 Sage 内单独配置。
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek:deepseek-v4-flash
LLM_LIGHT_MODEL=deepseek:deepseek-v4-flash
DEEPSEEK_API_KEY=
