{
	auto_https off
	admin off
}

:8080 {
	encode zstd gzip

	@backend path /api/* /health
	reverse_proxy @backend api:8000

	root * /srv
	try_files {path} /index.html
	file_server

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}
