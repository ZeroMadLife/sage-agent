# ============================================================
# TourSwarm 环境变量模板
# 复制为 .env 并填入真实值：cp .env.example .env
# ============================================================

# ---------- 第三方 API ----------
# 高德地图 Web 服务 Key（个人认证 30万次/日）
AMAP_API_KEY=your_amap_web_service_key_here

# 和风天气 API Key（非商业 5万次/月）
QWEATHER_API_KEY=your_qweather_key_here
# 和风天气个人专属 API Host（2026年起公共地址已停用，需在控制台 → 设置获取）
QWEATHER_BASE_URL=https://your-host.re.qweatherapi.com/v7
QWEATHER_GEO_URL=https://your-host.re.qweatherapi.com/geoapi/v2

# 备用天气源：彩云天气（1000次/天）
CAIYUN_API_KEY=your_caiyun_key_here

# ---------- LLM ----------
# 供应商：deepseek / doubao / openai_proxy / openai / anthropic / deepseek_anthropic
# deepseek            - DeepSeek 官方（OpenAI 兼容）
# doubao              - 火山引擎豆包（多模态，推荐做主模型）
# openai_proxy        - 180txt 中转站（兼容 OpenAI 格式）
# openai              - OpenAI 官方
# anthropic           - Anthropic 官方（原生 API）
# deepseek_anthropic  - DeepSeek 官方（Anthropic 兼容端点）
LLM_PROVIDER=doubao

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 模型：deepseek-v4-flash（默认）/ deepseek-v4-pro（可选）
DEEPSEEK_MODEL=deepseek-v4-flash

# 火山引擎豆包（OpenAI 兼容格式，多模态）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
DOUBAO_MODEL=Doubao-Seed-2.0-pro

# 180txt 中转站（OpenAI 兼容格式）
OPENAI_PROXY_API_KEY=
OPENAI_PROXY_BASE_URL=https://serve.wzjself.org/v1
OPENAI_PROXY_MODEL=gpt-5.4-mini

# OpenAI 官方（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic 官方（原生 API，可选）
ANTHROPIC_API_KEY=

# 主模型（复杂编排）与轻量模型（简单意图路由）
# 格式：provider:model，如 doubao:Doubao-Seed-2.0-pro
# Anthropic 原生路径可用 anthropic:claude-sonnet-4-20250514 或 deepseek_anthropic:deepseek-v4-flash
LLM_MODEL=doubao:Doubao-Seed-2.0-pro
LLM_LIGHT_MODEL=deepseek:deepseek-v4-flash

# ---------- 数据库 ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tourswarm
POSTGRES_PASSWORD=tourswarm_dev
POSTGRES_DB=tourswarm

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- 应用 ----------
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SAGE_DEERFLOW_V2_ENABLED=true
SAGE_CODING_DEFAULT_RUNTIME_PROFILE=deerflow_v2
# 紧急回滚：把默认值改为 legacy；需要完全关闭 V2 时再把上方开关设为 false。
# 本地开发使用 local_workspace；production/staging 启用 DeerFlow V2 时必须使用 container。
SAGE_CODING_SANDBOX_PROVIDER=local_workspace
SAGE_CODING_SANDBOX_IMAGE=python:3.11-slim
SAGE_WEB_SEARCH_ENABLED=false
# Self-hosted SearXNG base URL. JSON output must be enabled on the instance.
SAGE_WEB_SEARCH_ENDPOINT=
SAGE_WEB_SEARCH_TIMEOUT_SECONDS=10
APP_SECRET_KEY=change-me-in-production
# 访问口令，多个用英文逗号分隔；留空时本地开发允许匿名
APP_ACCESS_CODES=tour2026,friend01,classmate02

# ---------- V7 云端认证 ----------
# GitHub OAuth 仅用于身份登录，默认不申请私有仓库 repo scope。
# 私有仓库将在 V7.1 通过 GitHub App 按仓库授权。
CLOUD_DEV_LOGIN_ENABLED=false
CLOUD_SECURE_COOKIES=false
CLOUD_FRONTEND_URL=http://localhost:5173
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/cloud/auth/github/callback
GITHUB_OAUTH_SCOPE="read:user user:email"
# 两个密钥用途必须分离，生产环境分别使用至少 32 字符的随机值。
GITHUB_OAUTH_TRANSACTION_SECRET=
GITHUB_TOKEN_ENCRYPTION_SECRET=
# Independent AES-GCM key material for user-supplied LLM Provider API keys.
MODEL_PROVIDER_ENCRYPTION_SECRET=

# ---------- V7.2 本地知识空间 ----------
# Git-backed LLM Wiki 仓库；云端多租户隔离完成前只在 development 开放写入。
KNOWLEDGE_WORKSPACE_ROOT=
# 默认使用 Knowledge Repository/.sage/knowledge.sqlite3；可显式覆盖。
KNOWLEDGE_DATABASE_PATH=
# 服务端白名单 Markdown/Obsidian 目录。浏览器只能提交此目录下的相对路径。
KNOWLEDGE_SOURCE_ROOT=
KNOWLEDGE_SOURCE_ID=sage-learning
KNOWLEDGE_SOURCE_LABEL=Sage Learning
KNOWLEDGE_SOURCE_KIND=obsidian
# PostgreSQL migration 与 Redis 就绪后开启持久批量任务；失败时应用拒绝静默降级。
KNOWLEDGE_JOBS_ENABLED=false

# ---------- 前端 ----------
# Vue3 Web 端开发服务器端口
VITE_DEV_PORT=5173
# UniApp H5 预览端口
UNIAPP_DEV_PORT=5174
# API 基础地址（前端连接后端用）
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/api/v1

# LangSmith 链路追踪（可选）
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tourswarm
