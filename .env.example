# ============================================================
# TourSwarm 环境变量模板
# 复制为 .env 并填入真实值：cp .env.example .env
# ============================================================

# ---------- 第三方 API ----------
# 高德地图 Web 服务 Key（个人认证 30万次/日）
AMAP_API_KEY=your_amap_web_service_key_here

# 和风天气 API Key（非商业 5万次/月）
QWEATHER_API_KEY=your_qweather_key_here

# 备用天气源：彩云天气（1000次/天）
CAIYUN_API_KEY=your_caiyun_key_here

# ---------- LLM ----------
# 供应商：openai / anthropic / zhipu / dashscope
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# 主模型（复杂编排）与轻量模型（简单意图路由）
LLM_MODEL=gpt-4o-mini
LLM_LIGHT_MODEL=gpt-4o-mini

# 国产模型（可选，零成本测试用）
# DASHSCOPE_API_KEY=
# ZHIPU_API_KEY=

# ---------- 数据库 ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tourswarm
POSTGRES_PASSWORD=tourswarm_dev
POSTGRES_DB=tourswarm

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 向量库 Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ---------- 应用 ----------
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-in-production

# ---------- 前端 ----------
# Vue3 Web 端开发服务器端口
VITE_DEV_PORT=5173
# UniApp H5 预览端口
UNIAPP_DEV_PORT=5174
# API 基础地址（前端连接后端用）
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/api/v1

# LangSmith 链路追踪（可选）
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tourswarm

# Mem0 配置
MEM0_VECTOR_STORE=qdrant
MEM0_EMBEDDER_MODEL=BAAI/bge-large-zh-v1.5
